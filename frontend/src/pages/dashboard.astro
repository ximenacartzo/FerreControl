---
import '../styles/global.css';
import ReportsDashboard from '../components/vue/ReportsDashboard.vue';
---

<nav class="flex items-center justify-between p-4 bg-white border-b" style="border-color: var(--border)">
  <div class="flex gap-4">
    <a href="/dashboard" class="font-semibold">Dashboard</a>
    <a href="/inventario/lista">Inventario</a>
    <a href="/inventario/registrar">Nuevo producto</a>
    <a href="/ventas/pos">Punto de Venta</a>
  </div>
  
  <button onclick="logout()" class="btn" style="border-color: #fee2e2; color: #dc2626;">
    Salir
  </button>
</nav>

<div class="bg-slate-50 min-h-screen p-8">
  <ReportsDashboard client:load />
</div>

<script type="module">
  async function logout() {
    const token = localStorage.getItem('token');
    try {
      if (token) {
        await fetch('http://127.0.0.1:8000/api/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + token
          }
        });
      }
    } catch (e) {
      console.error('Error al cerrar sesión:', e);
    } finally {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      window.location.href = '/';
    }
  }
  window.logout = logout;
</script>